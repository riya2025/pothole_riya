# Backend environment variables
# Copy this to .env and fill in your values

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civic_db
POSTGRES_URL=
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
GROQ_API_KEY=your-groq-api-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=uploads

# ── Cloudinary (REQUIRED on Render for report photos) ─────────────────────────
# Render wipes local uploads/ on every redeploy. Cloudinary keeps images permanently.
# 1. Sign up at https://cloudinary.com (free tier)
# 2. Dashboard → copy Cloud name, API Key, API Secret
# 3. Add all three to Render → Environment for civic-issue-api
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Auto-email complaints to GHMC (with the original photo attached) ──────────
# Optional. If these are set, every submitted report is emailed to GHMC_EMAIL
# with the original uploaded photo as an attachment. If left blank, emailing is
# skipped and the rest of the app works normally.
# Example (Gmail): create an App Password at https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
# Example (SendGrid): SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASSWORD=<api key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# GHMC Public Grievance Cell (Commissioner). Override with a test inbox while verifying.
GHMC_EMAIL=commissioner-ghmc@gov.in
