# Backend environment variables
# Copy this to .env and fill in your values

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civic_db
# POSTGRES_URL: production database. For high concurrency (many users at once),
# use Supabase's CONNECTION POOLER string (Supabase → Project Settings →
# Database → Connection pooling → "Transaction" mode, port 6543), NOT the direct
# 5432 connection. The pooler (pgbouncer) handles far more concurrent clients
# and prevents "too many connections" 500 errors under load.
POSTGRES_URL=
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
GROQ_API_KEY=your-groq-api-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=uploads

# ── Cloudinary (REQUIRED on Render for report photos) ─────────────────────────
# Render wipes local uploads/ on every redeploy. Cloudinary keeps images permanently.
# 1. Sign up at https://cloudinary.com (free tier)
# 2. Dashboard → copy Cloud name, API Key, API Secret
# 3. Add all three to Render → Environment for civic-issue-api
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
